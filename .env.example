# Path to the root data directory (containing image_index.csv, thermal_temps/, thermal_images/)
DATA_DIR=./data

# Output directory for aligned rendered images
OUTPUT_DIR=./outputs

# Default palette: WHITE_HOT | IRON | RAINBOW_HC | ARCTIC
DEFAULT_PALETTE=IRON

# Percentile clamping defaults (set to 0 and 100 to disable clamping)
DEFAULT_LOW_PERCENTILE=2.0
DEFAULT_HIGH_PERCENTILE=98.0
